# App
NODE_ENV=production
PORT=3000
APP_URL=https://api-vaulted.casacam.net

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vaulted

# PostgreSQL — Neon.tech
# Get from: https://console.neon.tech → Connection string
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=vaulted
POSTGRES_USER=
POSTGRES_PASSWORD=
# Full connection string — pegar el de Neon.tech (incluye SSL automático)
DATABASE_URL=
# Poner true solo en el primer deploy para crear las tablas, luego cambiar a false
TYPEORM_SYNC=true

# Redis — Upstash
# Get from: https://console.upstash.com → Redis → Connect → .env
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
# Or use full URL: rediss://:password@host:port
REDIS_URL=

# Google AI (Gemini — chat + embeddings + vision)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=
AI_CHAT_MODEL=gemini-2.5-flash
AI_EMBEDDING_MODEL=gemini-embedding-001
AI_EMBEDDING_DIMS=3072
AI_CHAT_RATE_LIMIT_PER_MINUTE=20
AI_VISION_MODEL=gemini-2.5-flash

# GCP Storage (media uploads)
GCP_PROJECT_ID=tennis-management-fcd54
GCP_STORAGE_BUCKET=
GCP_KEY_FILE=
