# App
NODE_ENV=production
PORT=3000
APP_URL=https://api-vaulted.casacam.net

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d
MEDIA_JWT_SECRET=
MEDIA_JWT_PREVIOUS_SECRET=

# Encryption — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ENCRYPTION_SALT is mandatory and must be at least 32 characters.
#   Existing deployments that used the legacy default must run infra/re-encrypt-salt.js
#   before changing this value and redeploying the API.
ENCRYPTION_KEY=
ENCRYPTION_SALT=

# ── OPTION A: Managed cloud DBs (current setup) ──────────────────────────────
# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vaulted

# PostgreSQL — Neon.tech
DATABASE_URL=
TYPEORM_SYNC=false

# Redis — Upstash (use rediss:// for TLS)
REDIS_URL=

# ── OPTION B: Self-hosted Docker fullstack (docker-compose-fullstack.prod.yml) ─
# Use start-prod-full.sh — these replace MONGODB_URI / DATABASE_URL / REDIS_URL above

# MongoDB root (admin only, not used by API)
MONGO_ROOT_USER=
MONGO_ROOT_PASSWORD=

# MongoDB app user (least-privilege, readWrite on vaulted db only)
# generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MONGO_APP_USER=vaulted_app
MONGO_APP_PASSWORD=

# PostgreSQL
POSTGRES_USER=vaulted
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vaulted

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# Suffix appended to CONFIG command rename (prevents unauthorized redis config changes)
# generate: node -e "console.log(require('crypto').randomBytes(8).toString('hex'))"
REDIS_ADMIN_SUFFIX=

# Backup encryption key (AES-256 — used to encrypt nightly DB dumps)
# generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKUP_ENCRYPTION_KEY=
BACKUP_RETAIN_DAYS=7

# Google AI (Gemini — chat + embeddings + vision)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=
AI_CHAT_MODEL=gemini-2.5-flash
AI_EMBEDDING_MODEL=gemini-embedding-001
AI_EMBEDDING_DIMS=3072
AI_CHAT_RATE_LIMIT_PER_MINUTE=20
AI_VISION_MODEL=gemini-2.5-flash

# GCP Storage (media uploads)
GCP_PROJECT_ID=tennis-management-fcd54
GCP_STORAGE_BUCKET=
GCP_KEY_FILE=
