# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# JWT
JWT_SECRET=change_me_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_in_production_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=change_me_encryption_key_min_32_chars

# MongoDB
MONGODB_URI=mongodb://mongodb:27017/vaulted

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vaulted
POSTGRES_USER=vaulted_user
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production

# GCP Storage (Phase 4)
GCP_PROJECT_ID=
GCP_STORAGE_BUCKET=
GCP_KEY_FILE=
GCP_STORAGE_PUBLIC=false

# Firebase FCM (Phase 7)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Email - Resend (Phase 7)
RESEND_API_KEY=
EMAIL_FROM=noreply@vaulted.app

# Sentry (Phase 10)
SENTRY_DSN=
